FROM jekyll/jekyll:4.2.2

WORKDIR /srv/jekyll

# Copy only the gem manifests first so `bundle install` is cached as its own
# layer - it re-runs only when Gemfile/Gemfile.lock change, not on every source
# edit. The site source is bind-mounted at runtime (see docker-compose.yml), so
# the image itself does not need a `COPY . .`.
COPY Gemfile Gemfile.lock ./

RUN bundle install

EXPOSE 4000
